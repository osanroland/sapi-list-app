{% extends 'layout/base.html.twig' %}

{% block content %}
<h2>Feliratkozók</h2>

<form method="get" action="/list/{{ listId }}/subscribers" class="mb-3 d-flex flex-wrap align-items-center gap-2">
    <select name="sort" class="form-select w-auto" onchange="this.form.submit()">
        <option value="">— Rendezés —</option>
        <option value="name_asc"  {{ sort == 'name_asc'  ? 'selected' : '' }}>Név A→Z</option>
        <option value="name_desc" {{ sort == 'name_desc' ? 'selected' : '' }}>Név Z→A</option>
        <option value="date_asc"  {{ sort == 'date_asc'  ? 'selected' : '' }}>Dátum régebbi→újabb</option>
        <option value="date_desc" {{ sort == 'date_desc' ? 'selected' : '' }}>Dátum újabb→régebbi</option>
    </select>

    <div class="form-check mb-0">
        <input class="form-check-input" type="checkbox"
               name="isActive" value="1" id="isActiveCheck"
               {{ isActive ? 'checked' : '' }}
               onchange="this.form.submit()">
        <label class="form-check-label" for="isActiveCheck">Csak aktív</label>
    </div>

    <div class="input-group w-auto">
        <input type="text" name="search" class="form-control"
               placeholder="Keresés név vagy e-mail alapján"
               value="{{ search }}">
        <button type="submit" class="btn btn-outline-secondary">Keresés</button>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Név</th>
            <th>E-mail</th>
            <th>Feliratkozás dátuma</th>
            <th>Státusz</th>
        </tr>
    </thead>
    <tbody>
        {% for subscriber in subscribers %}
            <tr>
                <td>{{ subscriber.fullName }}</td>
                <td>{{ subscriber.email }}</td>
                <td>{{ subscriber.subdate }}</td>
                <td>
                    <span class="badge {{ subscriber.active ? 'bg-success' : 'bg-secondary' }}">
                        {{ subscriber.active ? 'Aktív' : 'Inaktív' }}
                    </span>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4" class="text-center text-muted">Nincs megjelenítendő elem.</td>
            </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
